# Copy to .env.local and adjust paths.

# Path to the backend repo (used as cwd when shelling out to the brutus CLI).
BRUTUS_DIR=../brutus

# Path to the brutus executable (the one in the backend's venv).
BRUTUS_BIN=../brutus/.venv/bin/brutus

# Optional: override the SQLite path. Defaults to $BRUTUS_DIR/data/brutus.db
# BRUTUS_DB_PATH=../brutus/data/brutus.db
