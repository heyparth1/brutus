# Copy to .env and fill in your keys. .env is gitignored — never commit real secrets.

# --- GitHub (required: fetch, pr) ---
GITHUB_TOKEN=your_github_token_here

# --- LLM for classify/search: GLM via OpenCode Zen ---
OPENCODE_API_KEY=your_opencode_key_here
LLM_BASE_URL=https://opencode.ai/zen/go/v1
GLM_MODEL=glm-5.2
GLM_TEMPERATURE=0
BRUTUS_LLM_CMD=.venv/bin/python glm.py

# --- Repo setup planner: cheap Gemini model ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.5-flash
BRUTUS_SETUP_CMD=.venv/bin/python gemini.py

# --- Solve: interactive Claude session (default) ---
BRUTUS_SOLVER=claude
BRUTUS_CLAUDE_CMD=claude --dangerously-skip-permissions --model fable
BRUTUS_REVIEW_CMD=claude -p --model fable
BRUTUS_SANDBOX=local
